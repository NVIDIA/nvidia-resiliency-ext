{
  "schema_version": "restart_agent_config.v1",
  "config_id": "panel-with-qwen-route-variants",
  "config_version": 1,
  "routing": {
    "mode": "collect_all",
    "max_parallel_models": 8,
    "timeout_seconds": 600
  },
  "runtime": {
    "history": {
      "enabled": true,
      "max_attempts_per_job": 10,
      "max_total_records": 3000
    }
  },
  "restart_environment_context": {},
  "retry_policy": {
    "bounded_retry_allowed_retries": 1,
    "general_retry_allowed_retries": 3
  },
  "model_defaults": {
    "request": {
      "timeout_seconds": 120,
      "max_output_tokens": 64000,
      "temperature": 0,
      "top_p": 1
    },
    "reliability": {
      "max_retries": 1,
      "retry_backoff_seconds": 0.5
    },
    "tools": {
      "enabled": true,
      "advertisement": {
        "overview": true,
        "grep_log": true,
        "read_window": true,
        "get_evidence_objects": false
      },
      "max_rounds": 8
    },
    "reasoning": {
      "thinking_mode": "auto"
    }
  },
